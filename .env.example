# ==============================================================
# SOC Forge — Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) is safe to commit — it has no real secrets.
# ==============================================================


# --------------------------------------------------------------
# Django Core (required)
# --------------------------------------------------------------

# Generate a strong secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to True only in development — never in production
DEBUG=True

# Comma-separated list of allowed hostnames
# Development: localhost,127.0.0.1
# Production:  yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1


# --------------------------------------------------------------
# Database (required)
# --------------------------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://socforge:socforge@localhost:5432/socforge


# --------------------------------------------------------------
# Redis (optional — required for Celery async tasks)
# --------------------------------------------------------------
# If not set, investigations run synchronously and rate limiting
# falls back to in-memory cache (not suitable for production).
REDIS_URL=redis://localhost:6379/0


# --------------------------------------------------------------
# LLM — AI summaries, multi-provider (optional)
# Set LLM_PROVIDER to the provider you want to use.
# Only the API key for the selected provider needs to be filled in.
# --------------------------------------------------------------

# Provider to use for AI summaries
# Options: anthropic | openai | groq | grok | gemini
LLM_PROVIDER=anthropic

# Optional: override the default model for the selected provider
# Leave blank to use the provider default:
#   anthropic → claude-haiku-4-5-20251001
#   openai    → gpt-4o-mini
#   groq      → llama-3.3-70b-versatile
#   grok      → grok-3-mini
#   gemini    → gemini-2.0-flash
LLM_MODEL=

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI ChatGPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (Llama 3.3 70B, Mixtral…) — https://console.groq.com/keys
# Free tier: 14,400 requests/day
GROQ_API_KEY=

# xAI Grok — https://console.x.ai/
GROK_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
# Free tier available
GEMINI_API_KEY=


# ==============================================================
# Threat Intelligence API Keys (all optional)
# Add at least one to run real investigations.
# Free sources (ThreatFox, URLhaus, Malware Bazaar) work without a key.
# ==============================================================

# VirusTotal — https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/min, 500/day
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api
# Free tier: 1,000 requests/day
ABUSEIPDB_API_KEY=

# Shodan — https://account.shodan.io/
# Free tier: 1 request/sec (limited fields)
SHODAN_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
# Free with account registration
OTX_API_KEY=

# GreyNoise — https://www.greynoise.io/account/
# Free community tier available
GREYNOISE_API_KEY=

# Google Safe Browsing — https://console.developers.google.com/
# Free with Google account
GOOGLE_SAFEBROWSING_API_KEY=

# Hybrid Analysis — https://www.hybrid-analysis.com/profile/api
# Free with account registration
HYBRID_ANALYSIS_API_KEY=

# SecurityTrails — https://securitytrails.com/app/account/credentials
# Free tier: 50 requests/month
SECURITYTRAILS_API_KEY=

# abuse.ch (ThreatFox / MalwareBazaar / URLhaus)
# Free — register at https://bazaar.abuse.ch/account/
ABUSECH_AUTH_KEY=

# URLScan.io — https://urlscan.io/user/profile/
# Free with account registration
URLSCAN_API_KEY=

# Pulsedive — https://pulsedive.com/account/
# Free tier available
PULSEDIVE_API_KEY=

# Criminal IP — https://www.criminalip.io/mypage/information
# Free tier available
CRIMINAL_IP_API_KEY=

# ipinfo.io — https://ipinfo.io/account/token
# Free tier: 50,000 requests/month
IPINFO_API_KEY=

# IPQualityScore — https://www.ipqualityscore.com/user/settings
# Free tier: 5,000 requests/month
IPQUALITYSCORE_API_KEY=

# Censys — https://search.censys.io/account/api
# Free tier: 250 queries/month
CENSYS_API_ID=
CENSYS_API_SECRET=
